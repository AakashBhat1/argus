# Root compose secrets — copy to .env (or run scripts/generate-secrets.sh on
# the server, which creates it with strong random values). Never commit .env.

# Postgres superuser password for the surveillance database.
POSTGRES_PASSWORD=change_me

# MediaMTX API user (backend stream registration).
MEDIAMTX_API_PASSWORD=change_me

# MediaMTX publisher user (the relay laptop authenticates with this to push
# camera streams; anonymous publish is disabled).
MEDIAMTX_PUBLISH_PASSWORD=change_me

# Public IP or domain of this host. Advertised to browsers in WebRTC ICE
# candidates so the UDP media port (8189) is reachable from the internet.
# scripts/setup-tls.sh sets this to your domain automatically.
MEDIAMTX_PUBLIC_HOST=127.0.0.1
