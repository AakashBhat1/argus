# ─────────────────────────────────────────────────────────────────────────────
# Chatbot service environment variables
# Copy this file to .env and fill in the values for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── ROI events log ────────────────────────────────────────────────────────────
# Path to the JSONL file written by the backend's intrusion pipeline.
# In Docker Compose this is a shared named volume; adjust for local dev.
ROI_EVENTS_PATH=/app/roi_events/roi_events.jsonl

# Optional: directory for FAISS index, documents, and checkpoint files.
# Defaults to chatbot/project/data when unset.
CHATBOT_DATA_DIR=/app/project/data

# DB-first ingestion mode (default): postgres | jsonl
INGESTION_SOURCE=postgres

# Required when INGESTION_SOURCE=postgres (use read-only credentials in production)
CHATBOT_DATABASE_URL=postgresql+psycopg2://surveillance:surveillance@db:5432/surveillance

# Tenant scope for DB reads until auth-context propagation is wired end-to-end.
CHATBOT_TENANT_ID=1

# ── Embedding model ───────────────────────────────────────────────────────────
# HuggingFace model name for sentence embeddings.
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Device for embedding inference: cpu | cuda | mps
EMBEDDING_DEVICE=cpu

# Batch size for encoding documents
EMBEDDING_BATCH_SIZE=256

# Set to "1" to use only locally cached model (no download; use after first run).
# Set to "0" to allow downloading from HuggingFace on first run.
# In Docker, the model is in volume chatbot_embedding_models at /app/models/embedding; see docs/EMBEDDING-MODEL-LOCAL.md.
EMBEDDING_LOCAL_FILES_ONLY=0

# ── Ingestion worker ──────────────────────────────────────────────────────────
# How often (seconds) the background worker polls for new events.
INGESTION_INTERVAL_SECONDS=5

# Maximum rows/lines to process per ingestion batch.
MAX_LINES_PER_BATCH=5000

# ── Vector store flush ────────────────────────────────────────────────────────
# Flush the FAISS index to disk every N seconds.
VECTOR_FLUSH_INTERVAL_SECONDS=60

# Also flush when this many new documents have been added.
VECTOR_FLUSH_DOC_THRESHOLD=1000

# ── Retrieval ─────────────────────────────────────────────────────────────────
# Default number of similar documents to retrieve per query.
TOP_K=8

# How often (seconds) the API reloads the FAISS index from disk.
INDEX_RELOAD_SECONDS=30

# ── Ollama LLM ────────────────────────────────────────────────────────────────
# Endpoint for the Ollama /api/generate API.
# Use http://ollama:11434/api/generate if running Ollama as a Docker service.
OLLAMA_ENDPOINT=http://127.0.0.1:11434/api/generate

# Ollama model to use (must be pulled in the Ollama instance).
OLLAMA_MODEL=qwen2.5:0.5b

# Keep the model loaded in memory for this duration.
OLLAMA_KEEP_ALIVE=24h

# Timeout (seconds) for Ollama requests.
OLLAMA_TIMEOUT_SECONDS=120
