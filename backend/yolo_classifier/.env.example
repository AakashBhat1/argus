# ─────────────────────────────────────────────────────────────────────────────
# Backend environment variables
# Copy this file to .env and fill in the values for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Async URL used by SQLAlchemy (FastAPI / asyncpg).
# Local dev default uses SQLite; set to Postgres for Docker / AWS RDS.
DATABASE_URL=sqlite+aiosqlite:///surveillance.db
# DATABASE_URL=postgresql+asyncpg://surveillance:surveillance@db:5432/surveillance

# When the primary (Postgres) database is unreachable at startup the backend
# now refuses to boot instead of silently falling back to SQLite (data written
# to the fallback is lost on container restart). Set to true only if you
# explicitly want the SQLite fallback behaviour.
ALLOW_DB_FALLBACK=false

# Sync URL used by Alembic migrations.
# DATABASE_URL_SYNC=postgresql+psycopg2://surveillance:surveillance@db:5432/surveillance

# ── Redis (optional) ─────────────────────────────────────────────────────────
# REDIS_URL=redis://redis:6379/0

# ── OpenVINO inference ────────────────────────────────────────────────────────
# Path to the OpenVINO IR model (.xml), relative to the backend/ directory.
OPENVINO_MODEL_PATH=models/yolo26n_int8.xml

# Target device: CPU | GPU | NPU | AUTO
OPENVINO_DEVICE=AUTO

# Model precision label (informational; actual precision is in the model file).
OPENVINO_PRECISION=INT8

# ── Stream URL validation ─────────────────────────────────────────────────────
# By default camera stream URLs pointing at private/loopback/link-local IPs
# (and plain http/https sources) are rejected to prevent SSRF. Set to true for
# local development with LAN cameras (DroidCam, IP Webcam, rtsp://localhost, …).
ALLOW_PRIVATE_STREAM_URLS=false

# ── Stream / batching ─────────────────────────────────────────────────────────
MAX_STREAMS=20
FRAME_SKIP=2
BATCH_ENABLED=True
BATCH_MAX_SIZE=8
INFERENCE_WORKERS=2

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Secret key used to sign JWTs. Change this to a long random string in prod.
# SECRET_KEY=change-me-in-production

# Access token lifetime in minutes (default 1440 = 24h). Shorten for stricter
# deployments; stateless JWTs cannot be revoked before they expire.
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Block 4 (optional): also write per-frame ROI events to DB table `roi_events`.
ROI_EVENTS_WRITE_DB=false

# Max psycopg2 connections for the synchronous background writers.
# Raise if many cameras write ROI/intent telemetry concurrently.
# ROI_PG_POOL_MAX=16
# INTENT_PG_POOL_MAX=8

# MediaMTX control API used for dynamic path registration.
# Set MEDIAMTX_ENABLED=false for local runs without MediaMTX.
MEDIAMTX_ENABLED=true
MEDIAMTX_API_BASE_URL=http://mediamtx:9997
MEDIAMTX_REQUEST_TIMEOUT_SECONDS=3
MEDIAMTX_API_USERNAME=mtx_api
MEDIAMTX_API_PASSWORD=mtx_api_change_me

# Data retention worker (runs in backend lifespan).
RETENTION_ENABLED=true
RETENTION_DAYS=30
RETENTION_RUN_INTERVAL_SECONDS=86400
RETENTION_DELETE_RESOLVED_ALERTS_ONLY=true
RETENTION_DELETE_ROI_EVENTS=false
RETENTION_DELETE_ANALYTICS_SNAPSHOTS=false

# ── Misc ──────────────────────────────────────────────────────────────────────
DEBUG=false
PYTHONUNBUFFERED=1
