# ─────────────────────────────────────────────────────────────────────────────
# Frontend environment variables
# Copy this file to .env.local for local development.
# In Docker Compose these are injected via the `environment:` block.
# ─────────────────────────────────────────────────────────────────────────────

# ── API URL (browser-side) ────────────────────────────────────────────────────
# Base path for API calls made from the browser.
# In Docker Compose the Next.js rewrite rule proxies /api/* → backend,
# so this should stay as /api/v1 (relative) in production.
# For local dev without Docker, point directly at the backend.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# Chat widget endpoint from browser (keep as relative path to avoid CORS).
NEXT_PUBLIC_CHATBOT_URL=/chat

# ── WebSocket URL (browser-side) ──────────────────────────────────────────────
# WebSocket endpoint for live detection events.
# In Docker Compose the Next.js server proxies this automatically.
# For local dev without Docker, point directly at the backend.
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ── MediaMTX WebRTC URL (browser-side) ────────────────────────────────────────
# Base URL for MediaMTX WHEP endpoint (live video feed).
# Default: http://localhost:8889. Override when MediaMTX is on a different host.
# NEXT_PUBLIC_MEDIAMTX_URL=http://localhost:8889

# ── Backend URL (server-side only, used by next.config.js rewrite) ────────────
# This variable is NOT exposed to the browser (no NEXT_PUBLIC_ prefix).
# It tells the Next.js server where to forward /api/* requests.
# In Docker Compose this is the internal Docker DNS name.
# NEXT_PRIVATE_BACKEND_URL=http://backend:8000
# Server-side target for `/chat` rewrite.
# NEXT_PRIVATE_CHATBOT_URL=http://localhost:8001
